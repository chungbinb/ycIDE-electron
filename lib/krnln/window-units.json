{
  "version": "1.0",
  "description": "核心支持库的基础窗口组件元数据。",
  "author": "ycIDE",
  "commandBindings": [
    {
      "command": "信息框",
      "commandEnglishName": "krnln.MsgBox",
      "emit": "MessageBoxW(NULL, {0}, ((const wchar_t*)({2}) && ((const wchar_t*)({2}))[0] != L'\\0') ? (const wchar_t*)({2}) : L\"信息框\", {1});"
    },
    {
      "command": "标准输出",
      "emit": "yc_debug_output_value({0});"
    },
    {
      "command": "调试输出",
      "emit": "yc_debug_output_value({0});"
    },
    {
      "command": "取本机名",
      "expr": "yc_get_local_hostname()"
    },
    {
      "command": "取主机名",
      "expr": "yc_get_local_hostname()"
    },
    {
      "command": "是否为调试版",
      "expr": "(YC_DEBUG_BUILD ? 1 : 0)"
    },
    {
      "command": "取当前目录",
      "expr": "yc_fs_get_current_dir()"
    },
    {
      "command": "创建目录",
      "expr": "yc_fs_create_dir({0})"
    },
    {
      "command": "删除目录",
      "expr": "yc_fs_remove_dir_all({0})"
    },
    {
      "command": "复制文件",
      "expr": "yc_fs_copy_file({0}, {1})"
    },
    {
      "command": "移动文件",
      "expr": "yc_fs_move_file({0}, {1})"
    },
    {
      "command": "删除文件",
      "expr": "yc_fs_delete_file({0})"
    },
    {
      "command": "文件更名",
      "expr": "yc_fs_rename_path({0}, {1})"
    },
    {
      "command": "文件是否存在",
      "expr": "yc_fs_file_exists({0})"
    },
    {
      "command": "取文件尺寸",
      "expr": "yc_fs_file_len({0})"
    },
    {
      "command": "取文件属性",
      "expr": "yc_fs_get_attr({0})"
    },
    {
      "command": "置文件属性",
      "expr": "yc_fs_set_attr({0}, {1})"
    },
    {
      "command": "读入文件",
      "expr": "yc_fs_read_file_bin({0})"
    },
    {
      "command": "到字节集",
      "expr": "yc_to_bin({0})"
    },
    {
      "command": "取字节集长度",
      "expr": "yc_bin_len({0})"
    },
    {
      "command": "改变驱动器",
      "expr": "yc_fs_change_drive({0})"
    },
    {
      "command": "改变目录",
      "expr": "yc_fs_change_dir({0})"
    },
    {
      "command": "取字节集左边",
      "expr": "yc_bin_left({0}, {1})"
    },
    {
      "command": "取字节集右边",
      "expr": "yc_bin_right({0}, {1})"
    },
    {
      "command": "取字节集中间",
      "expr": "yc_bin_mid({0}, {1}, {2})"
    },
    {
      "command": "寻找字节集",
      "expr": "yc_bin_find({0}, {1}, {2})"
    },
    {
      "command": "倒找字节集",
      "expr": "yc_bin_rfind({0}, {1}, {2})"
    },
    {
      "command": "字节集替换",
      "expr": "yc_bin_replace({0}, {1}, {2}, {3})"
    },
    {
      "command": "子字节集替换",
      "expr": "yc_bin_replace_sub({0}, {1}, {2}, {3}, {4})"
    },
    {
      "command": "取空白字节集",
      "expr": "yc_bin_space({0})"
    },
    {
      "command": "取重复字节集",
      "expr": "yc_bin_repeat({0}, {1})"
    },
    {
      "command": "指针到字节集",
      "expr": "yc_bin_from_address((long long)({0}), {1})"
    },
    {
      "command": "指针到整数",
      "expr": "yc_ptr_to_int((long long)({0}))"
    },
    {
      "command": "指针到小数",
      "expr": "yc_ptr_to_float((long long)({0}))"
    },
    {
      "command": "指针到双精度小数",
      "expr": "yc_ptr_to_double((long long)({0}))"
    },
    {
      "command": "取字节集内整数",
      "expr": "yc_bin_get_int({0}, {1}, {2})"
    },
    {
      "command": "置字节集内整数",
      "emit": "yc_bin_set_int({0}, {1}, {2}, {3});"
    },
    {
      "command": "等于",
      "exprOp": "eq"
    },
    {
      "command": "不等于",
      "exprOp": "ne"
    },
    {
      "command": "小于",
      "exprOp": "lt"
    },
    {
      "command": "大于",
      "exprOp": "gt"
    },
    {
      "command": "小于或等于",
      "exprOp": "le"
    },
    {
      "command": "大于或等于",
      "exprOp": "ge"
    },
    {
      "command": "近似等于",
      "exprOp": "startsWith"
    },
    {
      "command": "并且",
      "exprOp": "and"
    },
    {
      "command": "或者",
      "exprOp": "or"
    },
    {
      "command": "取反",
      "exprOp": "not"
    },
    {
      "command": "取磁盘总空间",
      "expr": "yc_fs_disk_total_kb({opt0})"
    },
    {
      "command": "取磁盘剩余空间",
      "expr": "yc_fs_disk_free_kb({opt0})"
    },
    {
      "command": "取磁盘卷标",
      "expr": "yc_fs_get_disk_label({opt0})"
    },
    {
      "command": "置磁盘卷标",
      "expr": "yc_fs_set_disk_label({opt0}, {1})"
    },
    {
      "command": "寻找文件",
      "expr": "yc_fs_dir({opt0}, {1})"
    },
    {
      "command": "取临时文件名",
      "expr": "yc_fs_get_temp_file_name({opt0})"
    },
    {
      "command": "写到文件",
      "exprBuilder": "writeFileBins"
    },
    {
      "command": "输出调试文本",
      "emitBuilder": "outputDebugText"
    },
    {
      "command": "暂停",
      "emitBuilder": "pause"
    },
    {
      "command": "检查",
      "emitBuilder": "check"
    }
  ],
